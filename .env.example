# Caminhos padrao da automacao.
# Nesta etapa os caminhos ja sao resolvidos automaticamente a partir da pasta do projeto.
BOLETOS_PENDENTES_DIR=boletos/pendentes
BOLETOS_PROCESSADOS_DIR=boletos/processados
BOLETOS_REVISAO_DIR=boletos/revisao
BOLETOS_ERRO_DIR=boletos/erro
LOG_FILE=logs/app.log
RESULTADOS_JSON=logs/resultados.json

# Banco de dados SQL Server.
# Preencha estes dados somente no arquivo .env local.
DB_SERVER=
DB_PORT=1433
DB_NAME=
DB_USER=automacao_boletos
DB_PASSWORD=
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_TRUST_CERTIFICATE=yes
DB_TIMEOUT=30

# Opcional: CNPJ usado em python src/teste_conexao.py
TESTE_CNPJ=03652501000493
